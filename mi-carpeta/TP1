## Parte 3: Conociendo la informalidad 
### 10. Siguiendo las definiciones de Maurizo & Monsalvo (2021), utilice la definición asignada de informalidad a su grupo. Expliquen brevemente las decisiones tomadas y las variables del diccionario que utilizaron para construir el indicador. Presente una tabla doble entrada con el porcentaje de trabajadores informales y formales, para el total de la población, mujeres y hombres en cada año. Comente los resultados en 1 parrafo.
asalariados = ocupados[
    ocupados["CAT_OCUP"] == 3
].copy()
asalariados["grupo"] = ""
#### Formal wage employees
asalariados.loc[
    asalariados["PP07H"] == 1,
    "grupo"
] = "Formal wage employees"
#### Upper-tier informal wage employees
##### Asalariados no registrados de nivel superior
asalariados.loc[
    (asalariados["PP07H"] == 2) &
    (asalariados["PP07I"] == 1),
    "grupo"
] = "Upper-tier informal wage employees"
asalariados = asalariados[
    asalariados["grupo"] != ""
].copy()
asalariados["sexo"] = asalariados["CH04"].map(
    {
        1:"Hombre",
        2:"Mujer"
    }
)
tabla_total = (
    asalariados
    .groupby(
        [
            "ANO4",
            "grupo"
        ]
    )
    .size()
    .reset_index(name="cantidad")
)
tabla_total["porcentaje"] = (
    tabla_total
    .groupby("ANO4")["cantidad"]
    .transform(
        lambda x: x/x.sum()*100
    )
)
tabla_total["porcentaje"] = (
    tabla_total["porcentaje"]
    .round(2)
)
print("Tabla total")
display(tabla_total)
tabla_sexo = (
    asalariados
    .groupby(
        [
            "ANO4",
            "sexo",
            "grupo"
        ]
    )
    .size()
    .reset_index(name="cantidad")
)
tabla_sexo["porcentaje"] = (
    tabla_sexo
    .groupby(
        [
            "ANO4",
            "sexo"
        ]
    )["cantidad"]
    .transform(
        lambda x:x/x.sum()*100
    )
)
tabla_sexo["porcentaje"] = (
    tabla_sexo["porcentaje"]
    .round(2)
)
print("Tabla por sexo")
display(tabla_sexo)
tabla_final = (
    tabla_sexo
    .pivot_table(
        index=[
            "ANO4",
            "sexo"
        ],
        columns="grupo",
        values="porcentaje"
    )
    .reset_index()
)
print("Tabla final")
display(tabla_final)
tabla_final.to_excel(
    "Tabla_informalidad_Maurizio_Monsalvo_Grupo6.xlsx",
