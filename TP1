### 9.	Realicen y comenten una tabla de estadistica descriptiva de todas las variables seleccionadas. La misma debe tener: número de observaciones, promedio, desvío estandar, min, p1, p25, p50, p75, p99 y max.
import pandas as pd
ocupados24 = ocupados[ocupados["ANO4"] == 2024].copy()
ocupados25 = ocupados[ocupados["ANO4"] == 2025].copy()
variables = [
    "CH04",
    "CH06",
    "CH07",
    "CH08",
    "NIVEL_ED",
    "ESTADO",
    "CAT_OCUP",
    "EMPLEO",
    "SECTOR",
    "PP04C",
    "PP04D_COD",
    "P21",
    "P47T",
    "PP07H",
    "PP07I"
]
def tabla_descriptiva(df):
    tabla = df[variables].describe(
        percentiles=[0.01, 0.25, 0.50, 0.75, 0.99]
    ).T
    tabla = tabla[[
        "count",
        "mean",
        "std",
        "min",
        "1%",
        "25%",
        "50%",
        "75%",
        "99%",
        "max"
    ]]
    tabla.columns = [
        "Observaciones",
        "Promedio",
        "Desv. Est.",
        "Mínimo",
        "P1",
        "P25",
        "P50",
        "P75",
        "P99",
        "Máximo"
    ]
    return tabla.round(2)
tabla2024 = tabla_descriptiva(ocupados24)
tabla2025 = tabla_descriptiva(ocupados25)
print("="*60)
print("ESTADÍSTICAS DESCRIPTIVAS - OCUPADOS 2024T4")
print("="*60)
display(tabla2024)
print("="*60)
